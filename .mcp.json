{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@0.0.38"
      ],
      "alwaysAllow": [
        "browser_navigate",
        "browser_click",
        "browser_press_key",
        "browser_type",
        "browser_take_screenshot",
        "browser_evaluate",
        "browser_console_messages",
        "browser_wait_for",
        "browser_snapshot",
        "browser_hover",
        "browser_close",
        "browser_fill_form"
      ]
    },
    "vision-mcp-server": {
      "command": "npx",
      "args": [
        "-y",
        "@z_ai/mcp-server"
      ],
      "env": {
        "Z_AI_API_KEY": "REDACTED",
        "Z_AI_MODE": "ZAI"
      },
      "transportType": "stdio",
      "autoApprove": [
        "analyze_image",
        "analyze_video"
      ],
      "alwaysAllow": [
        "analyze_image"
      ]
    },
    "web-reader": {
      "command": "npx",
      "args": [
        "-y",
        "@z_ai/mcp-server"
      ],
      "env": {
        "Z_AI_API_KEY": "REDACTED",
        "Z_AI_MODE": "ZAI"
      },
      "transportType": "stdio",
      "autoApprove": [
        "analyze_image",
        "analyze_video"
      ]
    },
    "web-search-prime": {
      "command": "npx",
      "args": [
        "-y",
        "@z_ai/mcp-server"
      ],
      "env": {
        "Z_AI_API_KEY": "REDACTED",
        "Z_AI_MODE": "ZAI"
      },
      "transportType": "sse",
      "autoApprove": []
    }
  }
}
